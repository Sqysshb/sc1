-- 1) Auto Nearest Mob (always works everywhere)
local function autoNearestMobLoop()
    while true do
        if not env.NIStop and T.autoNearestMobEnabled then
            local char = LP.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then
                local target = findClosestMob()
