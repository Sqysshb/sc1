local function moveToOre(ore)
    local root = getHumanoidRootPart()
    if not root then return end
    if CFG.AlternateMining then
        local hum = Player.Character and Player.Character:FindFirstChild("Humanoid")
        if hum then
            local t = ore:GetPivot().Position
            if (t-root.Position).Magnitude > CFG.WalkDistance then hum:MoveTo(t) end
        end
    else root.CFrame = ore:GetPivot()+Vector3.new(0,5,0) end
end

local function startMining()
    if not miningEnabled or isCapsuleActive or env.SqaysStop then return end
    if oreWatcher then pcall(oreWatcher.Disconnect,oreWatcher); oreWatcher=nil end
    local sel = {}
    if CFG.AlternateMining then
        for _,n in ipairs(CFG.AlternateOreSelection) do sel[n]=true end
    else for n,v in pairs(activeOres) do if v then sel[n]=true end end end
    local ore = findBestOre(sel)
    if ore then
        currentOre = ore; moveToOre(ore)
        oreWatcher = ore.AncestryChanged:Connect(function(_,p)
            if not p or not ore:FindFirstChild("Rock") then currentOre=nil; startMining() end
        end)
        spawnThread(function()
            while currentOre==ore and miningEnabled and not isCapsuleActive and not env.SqaysStop do
                if not isOreReady(ore) then currentOre=nil; startMining(); break end
                waitFor(0.1)
            end
        end)
    end
end

spawnThread(startMining)
spawnThread(function() while not env.SqaysStop do waitFor(2)
    if miningEnabled and not isCapsuleActive and not currentOre then startMining() end
end end)

-- ================================================
--  CAPSULE OPENER
-- ================================================
local function openCapsule()
    if isCapsuleActive or env.SqaysStop then return false end
    local char = Player.Character; local root = getHumanoidRootPart()
    if not (char and root) then return false end
    local ct = CFG.CapsuleType; local zone = CAPSULE_LOCATIONS[ct]
    if not zone then return false end
    local cost = CAPSULE_COSTS[ct]
    if CFG.CapsuleCheckPrism and getCurrency("Prism") < cost then
        warn("[Sqays Hub] Not enough Prism"); return false
    end

    isCapsuleActive = true
    local previousMiningState = miningEnabled
    if CFG.CapsulePauseMining then
        miningEnabled = false
        if oreWatcher then pcall(oreWatcher.Disconnect,oreWatcher); oreWatcher=nil end
        currentOre = nil
    end

    local saved = root.CFrame
    local arrived = false
    for attempt=1,5 do
        pcall(function() char:PivotTo(CFrame.new(zone)) end); waitFor(0.3+attempt*0.1)
        if (root.Position-zone).Magnitude<15 then arrived=true; break end
        if attempt>=3 then pcall(function() root.CFrame=CFrame.new(zone) end); waitFor(0.3) end
    end
    if not arrived then pcall(function() root.CFrame=CFrame.new(zone) end); waitFor(0.5) end

    local before = getCurrency("Prism")
    local rem = getRemote()
    if not rem then
        isCapsuleActive=false; miningEnabled=previousMiningState; startMining(); return false
    end

    local opened = false
    for i=1,5 do
        pcall(function() rem:FireServer("OpenCapsule",ct) end); waitFor(0.15*i)
        if getCurrency("Prism") < before then opened=true; break end
    end
    if not opened then
        for _=1,20 do waitFor(0.5)
            if getCurrency("Prism") < before then opened=true; break end
        end
    end

    for attempt=1,3 do
        pcall(function() char:PivotTo(saved) end); waitFor(0.3)
        if (root.Position-saved.Position).Magnitude<15 then break end
        if attempt==3 then pcall(function() root.CFrame=saved end) end
    end

    isCapsuleActive = false
    miningEnabled = previousMiningState
    startMining()
    return opened
end

spawnThread(function()
    while not env.SqaysStop do
        if CFG.AutoOpenCapsule then
            openCapsule()
            waitFor(CFG.CapsuleCycleCooldown)
        else
            waitFor(1)
        end
    end
end)

