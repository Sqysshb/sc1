local function createSnapshot()
    local s = {}
    for _, k in ipairs(SNAPSHOT_KEYS) do
        local v = CFG[k]
        if type(v) == "table" then
            local c, n = {}, 0
            for i, x in ipairs(v) do n = n + 1; c[n] = x end
            s[k] = c
        else
            s[k] = v
        end
    end
    -- Active state
    s._activeOres, s._activeRunes = {}, {}
    for n, v in pairs(activeOres)  do if v then s._activeOres[n]  = true end end
    for n, v in pairs(activeRunes) do if v then s._activeRunes[n] = true end end
    return s
end

local function applySnapshot(s)
    if not s then return end
    for _, k in ipairs(SNAPSHOT_KEYS) do
        if s[k] ~= nil then CFG[k] = s[k] end
    end
    if s._activeOres then
        for n in pairs(activeOres) do activeOres[n] = false end
        for n in pairs(s._activeOres) do activeOres[n] = true end
    end
    if s._activeRunes then
        for n in pairs(activeRunes) do activeRunes[n] = false end
        for n in pairs(s._activeRunes) do activeRunes[n] = true end
    end
    setAntiAFK(CFG.AntiAFK)
    if miningEnabled and not isCapsuleActive then
        cleanupMiningState()
        startMining()
    end
end

local function savePreset()
    savedPreset = createSnapshot()
    if HttpService then
        writeFileSafe(PRESET_FILE, HttpService:JSONEncode(savedPreset))
    end
end

local function loadPreset()
    if savedPreset then applySnapshot(savedPreset); return true end
    return false
end

local function deletePreset()
    savedPreset = nil
    deleteFileSafe(PRESET_FILE)
end

