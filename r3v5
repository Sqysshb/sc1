-- ===== REALM 3: AUTO JOIN TRIAL =====
local function shouldJoinTrial()
    local currentTime = os.date("*t")
    local minute = currentTime.min
    local second = currentTime.sec
    
    -- Join window: xx:29:00 to xx:30:00 OR xx:59:00 to xx:00:00
    if minute == 29 then
        return second >= 0
    elseif minute == 59 then
        return second >= 0
    elseif minute == 30 then
        return second == 0
    elseif minute == 0 then
        return second == 0
    end
    
    return false
end

local function teleportToTrial()
    local coord = TRIAL_COORDS[R3.difficulty]
    if not coord then return false end
    
    local char = LP.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    pcall(function()
        hrp.CFrame = CFrame.new(coord)
        pcall(function() hrp.AssemblyLinearVelocity = Vector3.new() end)
    end)
    
    return true
end

local function autoJoinLoop()
    R3.autoJoinRunning = true
    
    while R3.autoJoinEnabled and not env.NIStop do
        if shouldJoinTrial() then
            if teleportToTrial() then
                R3.trialStartTime = tick()
                Rayfield:Notify({
                    Title = "Realm 3",
                    Content = "Joined " .. R3.difficulty .. " Trial!",
                    Duration = 5,
                    Image = "info"
                })
                
                -- Auto leave logic
                if R3.autoLeaveEnabled then
                    local waitTime = R3.autoLeaveMinutes * 60
                    task.wait(waitTime)
                    if R3.autoLeaveEnabled then
                        leaveTrial()
                        Rayfield:Notify({
                            Title = "Realm 3",
                            Content = "Left Trial after " .. R3.autoLeaveMinutes .. " minutes",
                            Duration = 5,
                            Image = "info"
                        })
                    end
                end
            end
            
            task.wait(60)
        else
            task.wait(1)
        end
    end
    
    R3.autoJoinRunning = false
end

