-- --------------- Utility functions ---------------
local function httpGet(url)
    local success, result = pcall(function()
        if http and http.request then return http.request({Url=url,Method="GET"}).Body
        elseif syn and syn.request then return syn.request({Url=url,Method="GET"}).Body
        elseif request then return request({Url=url,Method="GET"}).Body
        elseif http_request then return http_request({Url=url,Method="GET"}).Body
        elseif game.HttpGet then return game:HttpGet(url) end
    end)
    return success and result or nil
end

local function waitFor(seconds)
    if task then task.wait(seconds) else wait(seconds) end
end

local function spawnThread(func)
    if task then task.spawn(func) else coroutine.wrap(func)() end
end

-- --------------- Safe file I/O ---------------
local function fileExists(path)
    local success, exists = pcall(function()
        return isfile and isfile(path)
    end)
    return success and exists
end

local function readFileSafe(path)
    if not fileExists(path) then return nil end
    local data
    pcall(function() data = readfile(path) end)
    return data
end

local function writeFileSafe(path, content)
    pcall(function() writefile(path, content) end)
end

local function deleteFileSafe(path)
    pcall(function()
        if fileExists(path) then delfile(path) end
    end)
end

