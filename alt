local function isOreReady(ore)
    if not (ore and ore:FindFirstChild("Rock")) then return false end
    local ui = ore:FindFirstChild("OresTopUI")
    if ui then local bar = ui:FindFirstChild("Bar")
        if bar then local health = bar:FindFirstChild("Health")
            if health and health.Text == "Respawning..." then return false end
        end
    end
    return true
end
local function findBestOre(sel)
    if not miningEnabled or isCapsuleActive then return nil end
    local f = Workspace:FindFirstChild("__GAME_CONTENT")
    local ores = f and f:FindFirstChild("Ores")
    if not ores then return nil end
    for i = #ORE_NAMES,1,-1 do
        if sel[ORE_NAMES[i]] then
            for _,o in ipairs(ores:GetChildren()) do
                if o.Name == ORE_NAMES[i] and isOreReady(o) then return o end
            end
        end
    end
    return nil
end
