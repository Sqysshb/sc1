-- Capsule
go(function() while true do
    if CFG.AutoOpenCapsule then
        local ct=CFG.CapsuleType; local zone=CapsuleLoc[ct]; local char=player.Character
        if not(char and hrp()) then tw(0.5)
        elseif not zone then warn("[Capsule] No zone for "..ct); tw(2)
        else
            local prism=currency("Prism") or 0
            local cost=CapsuleCost[ct] or math.huge
            if CFG.CapsuleCheckPrism and prism<cost then
                warn("[Capsule] Not enough Prism: "..prism); tw(1)
            else
                if CFG.CapsulePauseMining then CFG.AutoRollTier=false; tw(0.1) end
                local saved=char:GetPivot()
                char:PivotTo(CFrame.new(zone)); tw(CFG.CapsuleZoneWait)
                local before=currency("Prism") or 0
                fire("OpenCapsule",ct); tw(CFG.CapsuleReturnWait)
                local after=currency("Prism") or 0
                char:PivotTo(saved)
                if CFG.CapsulePauseMining then CFG.AutoRollTier=true end
                warn("[Capsule] "..(after<before and "Opened "..ct.." (-"..(before-after).." Prism)" or "No decrease - raise Zone Wait"))
                tw(CFG.CapsuleCycleCooldown)
            end
        end
    else tw(0.1) end
end end)

