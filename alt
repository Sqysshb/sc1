    if raw then
        local ok,data = pcall(function() return HttpService:JSONDecode(raw) end)
        if ok and type(data)=="table" then savedPreset=data end
    end
end
local SNAPSHOT_KEYS = {
    "AutoHarvest","AutoHarvest2","AutoHarvest3","AutoRollTier","AutoHitTree",
    "AutoWaterPump","AutoBlazeQuest","AutoConvertWoodToAsh","AutoExchangeGems",
    "AntiAFK","AutoGainFire","AutoUpgradeNoob","AutoUpgradeGems",
    "AutoUpgradePlanks","AutoUpgradeWater","AutoOpenChest","AutoRollAura",
    "AutoOpenCapsule","AlternateMining","CapsulePauseMining","CapsuleCheckPrism",
    "SelectedNoobUpgrades","SelectedGemUpgrades","SelectedPlankUpgrades",
    "SelectedWaterUpgrades","AlternateOreSelection","GemsToExchange",
    "ChestType","CapsuleType",
    "MiningSpeed","HarvestSpeed","TierSpeed","RuneSpeed","TreeSpeed",
    "WaterPumpSpeed","IceConvertSpeed","AshConvertSpeed","BlazeQuestSpeed",
    "ExchangeGemsSpeed","GainFireSpeed","RollAuraSpeed",
    "UpgradeNoobSpeed","UpgradeGemsSpeed","UpgradePlanksSpeed","UpgradeWaterSpeed",
    "WalkDistance","CapsuleCycleCooldown",
}
local function createSnapshot()
    local s = {}
    for _,k in ipairs(SNAPSHOT_KEYS) do
        local v = CFG[k]
        if type(v)=="table" then local c={}; for i,x in ipairs(v) do c[i]=x end; s[k]=c
        else s[k]=v end
    end
    s._activeOres={}; for n,v in pairs(activeOres) do if v then s._activeOres[n]=true end end
    s._activeRunes={}; for n,v in pairs(activeRunes) do if v then s._activeRunes[n]=true end end
    return s
end
local function applySnap(s)
    if not s then return end
    for _,k in ipairs(SNAPSHOT_KEYS) do if s[k]~=nil then CFG[k]=s[k] end end
    if s._activeOres then for n,v in pairs(s._activeOres) do activeOres[n]=v end end
    if s._activeRunes then for n,v in pairs(s._activeRunes) do activeRunes[n]=v end end
    setAntiAFK(CFG.AntiAFK)
    if miningEnabled and not isCapsuleActive then
        if oreWatcher then pcall(oreWatcher.Disconnect,oreWatcher); oreWatcher=nil end
        currentOre=nil; startMining()
    end
end
local function savePreset()
    savedPreset = createSnapshot(); writeFileSafe(PRESET_FILE, HttpService:JSONEncode(savedPreset))
end
local function loadPreset()
    if savedPreset then applySnap(savedPreset); return true end
    return false
end
local function deletePreset()
    savedPreset=nil; deleteFileSafe(PRESET_FILE)
end
if savedPreset then applySnap(savedPreset) end

