local SNAP_KEYS = {
    "AutoHarvest","AutoHarvest2","AutoHarvest3","AutoRollTier","AutoHitTree",
    "AutoWaterPump","AutoBlazeQuest","AutoConvertWoodToAsh","AutoExchangeGems",
    "AntiAFK","AutoGainFire","AutoUpgradeNoob","AutoUpgradeGems",
    "AutoUpgradePlanks","AutoUpgradeWater","AutoOpenChest","AutoRollAura",
    "AutoOpenCapsule","AlternateMining","CapsulePauseMining","CapsuleCheckPrism",
    "SelectedNoobUpgrades","SelectedGemUpgrades","SelectedPlankUpgrades",
    "SelectedWaterUpgrades","AlternateOreSelection","GemsToExchange",
    "ChestType","CapsuleType",
    "MiningSpeed","HarvestSpeed","TierSpeed","RuneSpeed","TreeSpeed",
    "WaterPumpSpeed","IceConvertSpeed","AshConvertSpeed","BlazeQuestSpeed",
    "ExchangeGemsSpeed","GainFireSpeed","RollAuraSpeed",
    "UpgradeNoobSpeed","UpgradeGemsSpeed","UpgradePlanksSpeed","UpgradeWaterSpeed",
    "WalkDistance","CapsuleCycleCooldown","CapsuleZoneWait","CapsuleReturnWait",
}

local function snapshot()
    local s={}
    for _,k in ipairs(SNAP_KEYS) do
        local v=CFG[k]
        if type(v)=="table" then
            local c={}; for i,x in ipairs(v) do c[i]=x end; s[k]=c
        else s[k]=v end
    end
    s._M2={}; for n,v in pairs(M2) do if v then s._M2[n]=true end end
    s._Runes={}; for n,v in pairs(Runes) do if v then s._Runes[n]=true end end
    return s
end

local function applySnap(s)
    for _,k in ipairs(SNAP_KEYS) do if s[k]~=nil then CFG[k]=s[k] end end
    if s._M2    then for n,v in pairs(s._M2)    do M2[n]=v    end end
    if s._Runes then for n,v in pairs(s._Runes) do Runes[n]=v end end
    setAntiAFK(CFG.AntiAFK)
    warn("[Sqays] Preset applied for user: " .. UserID)
end

local function saveUserPreset()
    UserPresets[UserID] = snapshot()
    savePresetsToDisk()
    warn("[Sqays] Preset saved for user: " .. UserID)
end

local function loadUserPreset()
    if UserPresets[UserID] then
        applySnap(UserPresets[UserID])
        return true
    end
    warn("[Sqays] No preset found for user: " .. UserID)
    return false
end

-- Auto-load user preset BEFORE GUI creation
if UserPresets[UserID] then
    applySnap(UserPresets[UserID])
    warn("[Sqays] Auto-loaded preset for user: " .. UserID)
end

