-- Auto Walk to Humanoid
local env = getgenv and getgenv() or _G
if env.AWTHLoaded then return end
env.AWTHLoaded = true; env.AWTHStop = false

-- ===== SERVICES =====
local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local WS = game:GetService("Workspace")
local RunService = game:GetService("RunService")

-- ===== STATE =====
local S = {
    enabled = false,
    running = false
}

-- ===== FIND CLOSEST HUMANOID =====
local function findClosestHumanoid()
    local closest = nil
    local closestDist = math.huge
    
    for _, obj in ipairs(WS:GetDescendants()) do
        if obj:IsA("Humanoid") then
            local hrp = obj.Parent:FindFirstChild("HumanoidRootPart")
            if hrp and hrp:IsA("BasePart") then
                local character = obj.Parent
                if character ~= LP.Character then
                    local hum = obj
                    if hum and hum.Health > 0 then
                        local playerHrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                        if playerHrp then
                            local dist = (playerHrp.Position - hrp.Position).Magnitude
                            if dist < closestDist then
                                closestDist = dist
                                closest = hrp
                            end
                        end
                    end
                end
            end
        end
    end
    
    return closest
end

-- ===== AUTO WALK LOOP =====
local function autoWalkLoop()
    S.running = true
    
    while S.enabled and not env.AWTHStop do
        local target = findClosestHumanoid()
        if not target then
            task.wait(0.1)
            continue
        end
        
        local char = LP.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then task.wait(0.1); continue end
        
        local targetHum = target.Parent and target.Parent:FindFirstChildOfClass("Humanoid")
        if not targetHum or targetHum.Health <= 0 then
            continue
        end
        
        local dist = (hrp.Position - target.Position).Magnitude
        if dist > 5 then
            hum:MoveTo(target.Position)
            
            while S.enabled and not env.AWTHStop do
                local newTargetHum = target.Parent and target.Parent:FindFirstChildOfClass("Humanoid")
                if not newTargetHum or newTargetHum.Health <= 0 then
                    break
                end
                
                local newDist = (hrp.Position - target.Position).Magnitude
                if newDist <= 5 then
                    break
                end
                
                task.wait(0.05)
            end
        end
        
        task.wait(0.05)
    end
    
    S.running = false
end

-- ===== FLUENT UI =====
local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
if not Fluent then warn("[Auto Walk] Failed to load Fluent UI"); return end

local Window = Fluent:CreateWindow({
    Title = "Auto Walk to Humanoid",
    SubTitle = "Walks to closest humanoid",
    TabWidth = 130,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = true,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.K
})

local Tabs = {
    Main = Window:AddTab({ Title = "Auto Walk", Icon = "🚶" })
}

Tabs.Main:AddToggle("AutoWalkToggle", {
    Title = "Enable Auto Walk",
    Description = "Automatically walks to the closest humanoid",
    Default = false,
    Callback = function(v)
        S.enabled = v
        if v and not S.running then
            task.spawn(autoWalkLoop)
        end
    end
})

Tabs.Main:AddParagraph({
    Title = "Info",
    Content = "Automatically walks to the closest humanoid using normal Roblox walking animation."
})

print("[Auto Walk] Ready")
