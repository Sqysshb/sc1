-- Helpers
local function remote()
    local n = RS:FindFirstChild("__Net"); return n and n:FindFirstChild("MainRemote")
end
local function fire(...)
    local r = remote(); if r then pcall(r.FireServer,r,...) end
end
local function currency(name)
    local c=player:FindFirstChild("CURRENCIES"); local f=c and c:FindFirstChild(name)
    local a=f and f:FindFirstChild("Amount");   local v=a and a:FindFirstChild("1")
    return v and tonumber(v.Value)
end
local function hrp() local c=player.Character; return c and c:FindFirstChild("HumanoidRootPart") end
local function oreReady(o)
    if not (o and o:FindFirstChild("Rock")) then return false end
    local ui=o:FindFirstChild("OresTopUI"); local b=ui and ui:FindFirstChild("Bar")
    local h=b and b:FindFirstChild("Health"); return not(h and h.Text=="Respawning...")
end
local function bestOre(sel)
    local gc=WS:FindFirstChild("__GAME_CONTENT"); local f=gc and gc:FindFirstChild("Ores")
    if not f then return end
    for i=#OreNames,1,-1 do local n=OreNames[i]
        if sel[n] then for _,o in ipairs(f:GetChildren()) do if o.Name==n and oreReady(o) then return o end end end
    end
end
local function farmHarvest()
    local gc=WS:FindFirstChild("__GAME_CONTENT"); local farm=gc and gc:FindFirstChild("Farm")
    if farm then for _,w in ipairs(farm:GetChildren()) do
        local cd=w:FindFirstChild("ClickDetector"); if cd then pcall(fireclickdetector,cd) end
    end end
end

