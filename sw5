--[[ -------------------- Capsule Opener -------------------- ]]

--- Teleport to `target` CFrame with retries, return true on success.
local function forceTeleport(target)
    local char = Player and Player.Character
    local root = getRoot()
    if not (char and root) then return false end

    for attempt = 1, 8 do
        tryCall(function() char:PivotTo(target) end)
        threadWait(0.15 + attempt * 0.05)
        if (root.Position - target.Position).Magnitude < 15 then return true end
        if attempt >= 4 then
            tryCall(function() root.CFrame = target end)
            threadWait(0.3)
        end
    end
    tryCall(function() root.CFrame = target end) -- final fallback
    threadWait(0.5)
    return (root.Position - target.Position).Magnitude < 15
end

local function openCapsule()
    if isCapsuleActive or env.SqaysStop then return false end

    local char = Player and Player.Character
    local root = getRoot()
    if not (char and root) then
        logVerbose("Capsule: No character")
        return false
    end

    local ct   = CFG.CapsuleType
    local data = CAPSULE_DATA[ct]
    if not data then return false end

    if CFG.CapsuleCheckPrism and getCurrency(data.currency) < data.cost then
        logInfo("Not enough " .. data.currency .. " for " .. ct .. " capsule (" .. tostring(data.cost) .. " needed)")
        return false
    end

    isCapsuleActive = true
    local prevMining = miningEnabled
    if CFG.CapsulePauseMining then
        miningEnabled = false
        cleanupMiningState()
    end

    local savedCFrame = root.CFrame

    -- Go to capsule zone
    forceTeleport(CFrame.new(data.pos))

    -- Attempt to open
    local cur = data.currency
    local before = getCurrency(cur)
    local remote = getRemote()
    local opened = false

    if remote then
        for i = 1, 20 do
            tryCall(function() remote:FireServer("OpenCapsule", ct) end)
            threadWait(0.1 + i * 0.05)
            if getCurrency(cur) < before then
                opened = true
                break
            end
        end
    else
        logError("Capsule: Remote not found")
    end

    if not opened then
        logError("Capsule: Failed to open after 20 attempts")
    end

    -- Return to original position
    forceTeleport(savedCFrame)

    isCapsuleActive = false
    miningEnabled = prevMining
    startMining()
    return opened
end

spawnThread(function()
    while not env.SqaysStop do
        if CFG.AutoOpenCapsule then
            openCapsule()
            threadWait(CFG.CapsuleCycleCooldown)
        else
            threadWait(1)
        end
    end
end)

