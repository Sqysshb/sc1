--[[ -------------------- Ore / Mining Helpers -------------------- ]]

local function isOreReady(ore)
    if not (ore and ore.Parent) then return false end
    if not ore:FindFirstChild("Rock") then return false end
    local ui = ore:FindFirstChild("OresTopUI")
    if ui then
        local bar = ui:FindFirstChild("Bar")
        if bar then
            local health = bar:FindFirstChild("Health")
            if health and health.Text == "Respawning..." then
                return false
            end
        end
    end
    return true
end

local function refreshOreCache()
    local now = (tryCall(tick) and tick()) or os.clock()
    if gameContentCache and oresCache and (now - lastCacheRefresh) < 0.25 then
        return oresCache
    end
    lastCacheRefresh = now
    if not Workspace then return nil end
    gameContentCache = Workspace:FindFirstChild("__GAME_CONTENT")
    if gameContentCache then
        oresCache = gameContentCache:FindFirstChild("Ores")
    else
        oresCache = nil
    end
    return oresCache
end

--- Find the highest-tier ready ore matching the selection set.
local function findBestOre(sel)
    if not (miningEnabled and not isCapsuleActive) then return nil end
    local ores = refreshOreCache()
    if not ores then return nil end
    for i = #ORE_NAMES, 1, -1 do
        local name = ORE_NAMES[i]
        if sel[name] then
            local direct = ores:FindFirstChild(name)
            if direct and isOreReady(direct) then return direct end
            for _, child in ipairs(ores:GetChildren()) do
                if child.Name == name and isOreReady(child) then
                    return child
                end
            end
        end
    end
    return nil
end

local function harvestFarm()
    if not Workspace then return end
    local gc = Workspace:FindFirstChild("__GAME_CONTENT")
    local farm = gc and gc:FindFirstChild("Farm")
    if not farm then return end
    for _, wheat in ipairs(farm:GetChildren()) do
        local cd = wheat:FindFirstChild("ClickDetector")
        if cd then fireClickDetector(cd) end
    end
end

local function moveToOre(ore)
    local root = getRoot()
    if not root then return false end
    local target = ore:GetPivot().Position + Vector3.new(2, 0, 2)
    if CFG.AlternateMining then
        local hum = getHumanoid()
        if hum and (target - root.Position).Magnitude > CFG.WalkDistance then
            hum:MoveTo(target)
        end
    else
        root.Position = target
    end
    return true
end

--[[ -------------------- Mining Engine (re-entrancy safe) -------------------- ]]

local function cleanupMiningState()
    if oreWatcher then
        tryCall(oreWatcher.Disconnect, oreWatcher)
        oreWatcher = nil
    end
    if healthMonitor and coroutine.status(healthMonitor) ~= "dead" then
        if hasCoroutineClose then tryCall(coroutine.close, healthMonitor) end
    end
    healthMonitor = nil
    currentOre = nil
end

local function startMining()
    if miningLock then return end
    if not miningEnabled or isCapsuleActive or env.SqaysStop then return end

    miningLock = true
    cleanupMiningState()

    -- Build selection set
    local sel = {}
    if CFG.AlternateMining then
        for _, n in ipairs(CFG.AlternateOreSelection) do
            sel[n] = true
        end
    else
        for n, v in pairs(activeOres) do
            if v then sel[n] = true end
        end
    end
    if not next(sel) then miningLock = false; return end

    -- Find target
    local ore = findBestOre(sel)
    if not ore then
        consecutiveOreFails = consecutiveOreFails + 1
        miningLock = false
        return
    end

    consecutiveOreFails = 0
    currentOre = ore
    moveToOre(ore)

    -- Watch for ore destruction
    oreWatcher = ore.AncestryChanged:Connect(function(_, parent)
        if parent and ore:FindFirstChild("Rock") then return end
        currentOre = nil
        if oreWatcher then
            tryCall(oreWatcher.Disconnect, oreWatcher)
            oreWatcher = nil
        end
        threadWait(CFG.MiningSpeed > 0 and CFG.MiningSpeed or 0.001)
        startMining()
    end)

    -- Health monitor (polled check for respawning ore)
    healthMonitor = coroutine.create(function()
        while currentOre == ore and miningEnabled and not isCapsuleActive and not env.SqaysStop do
            if not isOreReady(ore) then
                currentOre = nil
                if oreWatcher then
                    tryCall(oreWatcher.Disconnect, oreWatcher)
                    oreWatcher = nil
                end
                healthMonitor = nil
                startMining()
                return
            end
            threadWait(0.05)
        end
    end)
    trackThread(healthMonitor)
    tryCall(coroutine.resume, healthMonitor)

    miningLock = false
end

