--[[ -------------------- Bootstrap & Environment -------------------- ]]
local function tryCall(fn, ...)
    -- Unified pcall: returns (true, result) or (false, error_message)
    -- Use this for ALL external API calls — executor functions, Roblox API, etc.
    return pcall(fn, ...)
end

local function safeWarn(msg)
    tryCall(warn, msg)
end

