-- 5. Hatching (Eggs 1-5 and Egg 8)
local hatchRemote = game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("AuraRunnerHatchEgg")
 
local function createHatchToggle(eggName)
   Tab:CreateToggle({
      Name = "Auto Hatch Egg world2 " .. eggName,
      CurrentValue = false,
      Callback = function(Value)
         _G["Hatch"..eggName] = Value
         task.spawn(function()
            while _G["Hatch"..eggName] do
               local args = { [1] = { ["eggModelName"] = tostring(eggName) } }
               pcall(function() hatchRemote:InvokeServer(unpack(args)) end)
               task.wait(0.5)
            end
         end)
      end,
   })
end
 
for i = 1, 5 do createHatchToggle(i) end
