--[[ -------------------- Core Utilities -------------------- ]]

--- Yield for `seconds` using the best available scheduler.
local function threadWait(seconds)
    if hasTaskWait then
        local ok = tryCall(task.wait, seconds)
        if ok then return end
    end
    local deadline = (tryCall(tick)) and tick() + seconds or os.clock() + seconds
    repeat tryCall(wait, 0.03) until (tryCall(tick) and tick() or os.clock()) >= deadline
end

--- Tracked coroutine registry (auto-prunes dead threads).
local _threadPruneCount = 0
local _activeThreads = {}

local function pruneDeadThreads()
    local alive, n = {}, 0
    for _, t in ipairs(_activeThreads) do
        if coroutine.status(t) ~= "dead" then
            n = n + 1
            alive[n] = t
        end
    end
    _activeThreads = alive
end

local function trackThread(co)
    if type(co) ~= "thread" then return end
    _threadPruneCount = _threadPruneCount + 1
    if _threadPruneCount > 50 then
        _threadPruneCount = 0
        pruneDeadThreads()
    end
    _activeThreads[#_activeThreads + 1] = co
end

local function killAllThreads()
    for _, t in ipairs(_activeThreads) do
        if coroutine.status(t) ~= "dead" then
            if hasCoroutineClose then tryCall(coroutine.close, t) end
        end
    end
    _activeThreads = {}
end

--- Spawn a tracked, error-guarded coroutine.
local function spawnThread(fn)
    local wrapper = function()
        local ok, err = tryCall(fn)
        if not ok then safeWarn("[Sqays Hub] Thread error: " .. tostring(err)) end
    end
    -- Prefer task.spawn (non-blocking), then coroutine, then defer, then sync
    if hasTaskSpawn then
        tryCall(task.spawn, wrapper)
        return
    end
    local co = coroutine.create(wrapper)
    if co then
        trackThread(co)
        tryCall(coroutine.resume, co)
        return
    end
    if hasTaskDefer then
        tryCall(task.defer, wrapper)
        return
    end
    tryCall(wrapper) -- desperate fallback: runs inline
end

--[[ -------------------- HTTP & File I/O -------------------- ]]

local HTTP_DRIVERS = {
    function(url) -- syn.request
        if not hasSynRequest then return nil end
        local r = syn.request({Url = url, Method = "GET"})
        return r and r.Body
    end,
    function(url) -- http.request
        if not http or not http.request then return nil end
        local r = http.request({Url = url, Method = "GET"})
        return r and r.Body
    end,
    function(url) -- request (global)
        if not request then return nil end
        local r = request({Url = url, Method = "GET"})
        return r and r.Body
    end,
    function(url) -- http_request (global)
        if not http_request then return nil end
        local r = http_request({Url = url, Method = "GET"})
        return r and r.Body
    end,
    function(url) -- game:HttpGet (Roblox built-in)
        if not (game and game.HttpGet) then return nil end
        return game:HttpGet(url)
    end,
    function(url) -- game:HttpGetAsync (newer Roblox)
        if not (game and game.HttpGetAsync) then return nil end
        return game:HttpGetAsync(url)
    end,
}

local function httpGet(url)
    for _, driver in ipairs(HTTP_DRIVERS) do
        local ok, body = tryCall(driver, url)
        if ok and type(body) == "string" and #body > 100 then
            return body
        end
    end
    return nil
end

local function fileExists(path)
    if not hasIsFile then return false end
    local ok, exists = tryCall(function() return isfile(path) end)
    return ok and exists
end

local function readFileSafe(path)
    if not (fileExists(path) and hasReadFile) then return nil end
    local data
    tryCall(function() data = readfile(path) end)
    return data
end

local function writeFileSafe(path, content)
    if not hasWriteFile then return end
    tryCall(function() writefile(path, content) end)
end

local function deleteFileSafe(path)
    if not fileExists(path) then return end
    tryCall(function() delfile(path) end)
end

--[[ -------------------- ClickDetector / Remote Helpers -------------------- ]]

local function fireClickDetector(cd)
    if not cd then return end
    if fireclickdetector then
        tryCall(fireclickdetector, cd)
        return
    end
    if firetouchinterest and Player and Player.Character then
        tryCall(firetouchinterest, cd, Player.Character, 0)
        tryCall(firetouchinterest, cd, Player.Character, 1)
        return
    end
    tryCall(function()
        local remote = cd:FindFirstChildOfClass("RemoteEvent")
        if remote then remote:FireServer() end
    end)
end

-- Remote resolution (cached for 5s to avoid repeated FindFirstChild)
local _remoteCache = nil
local _remoteCacheTime = 0

local function getRemote()
    local now = (tryCall(tick) and tick()) or os.clock()
    if _remoteCache and (now - _remoteCacheTime) < 5 then
        local parent
        tryCall(function() parent = _remoteCache.Parent end)
        if parent then return _remoteCache end
    end
    _remoteCacheTime = now
    tryCall(function()
        local net = ReplicatedStorage:FindFirstChild("__Net")
        _remoteCache = net and net:FindFirstChild("MainRemote")
    end)
    return _remoteCache
end

local function fireRemote(...)
    local remote = getRemote()
    if remote then
        tryCall(remote.FireServer, remote, ...)
    end
end

--[[ -------------------- Player State Helpers -------------------- ]]

local function getCurrency(name)
    if not Player then return 0 end
    local ok, result = tryCall(function()
        local currencies = Player:FindFirstChild("CURRENCIES")
        if not currencies then return nil end
        local folder = currencies:FindFirstChild(name)
        if not folder then return nil end
        local amount = folder:FindFirstChild("Amount")
        if not amount then return nil end
        local val = amount:FindFirstChild("1")
        return val and tonumber(val.Value)
    end)
    return (ok and result) or 0
end

local function getRoot()
    if not Player then return nil end
    local char = Player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    if not Player then return nil end
    local char = Player.Character
    if not char then return nil end
    return char:FindFirstChild("Humanoid")
end

