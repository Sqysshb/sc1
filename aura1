-- 1. Farming
local function startFarming(pos)
    return game:GetService("RunService").RenderStepped:Connect(function()
        local char = game.Players.LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = pos
        end
    end)
end
 
-- World 2 aggressive farming (teleports in bursts to bypass anti-cheat)
local function startAggressiveFarming(pos)
    return task.spawn(function()
        while _G.W2Farm do
            -- Teleport 4 times quickly
            for i = 1, 4 do
                if not _G.W2Farm then break end
                local char = game.Players.LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    char.HumanoidRootPart.CFrame = pos
                end
                task.wait(0.05)
            end
            -- Wait 2 seconds for character to fall
            task.wait(0.7)
        end
    end)
end
 
