-- --------------- Helpers ---------------
local function getRemote()
    local net = ReplicatedStorage:FindFirstChild("__Net")
    return net and net:FindFirstChild("MainRemote")
end
local function fireRemote(...)
    local remote = getRemote()
    if remote then pcall(remote.FireServer, remote, ...) end
end
local function getCurrency(name)
    local currencies = Player:FindFirstChild("CURRENCIES")
    if not currencies then return 0 end
    local folder = currencies:FindFirstChild(name)
    if not folder then return 0 end
    local amount = folder:FindFirstChild("Amount")
    if not amount then return 0 end
    local value = amount:FindFirstChild("1")
    return value and tonumber(value.Value) or 0
end
local function getHumanoidRootPart()
    local character = Player.Character
