--[[ -------------------- Automation Loop Factory -------------------- ]]

--- Create a generic tick loop: while running, if CFG[flag] then action() with delay.
local function createLoop(flag, speedKey, action)
    spawnThread(function()
        while not env.SqaysStop do
            if CFG[flag] then
                tryCall(action)
                threadWait(CFG[speedKey])
            else
                threadWait(0.1)
            end
        end
    end)
end

--- Create a multi-target upgrade loop with pre-built arg dispatch.
local function createUpgradeLoop(flag, speedKey, selKey, baseArgs)
    local argc = #baseArgs
    spawnThread(function()
        while not env.SqaysStop do
            if CFG[flag] and #CFG[selKey] > 0 then
                for _, target in ipairs(CFG[selKey]) do
                    if env.SqaysStop then break end
                    -- Inline dispatch (no table allocation on hot path)
                    if argc == 1 then
                        fireRemote(baseArgs[1], target)
                    elseif argc == 2 then
                        fireRemote(baseArgs[1], baseArgs[2], target)
                    elseif argc == 3 then
                        fireRemote(baseArgs[1], baseArgs[2], baseArgs[3], target)
                    else
                        fireRemote(table.unpack(baseArgs), target)
                    end
                end
                threadWait(CFG[speedKey])
            else
                threadWait(0.1)
            end
        end
    end)
end

