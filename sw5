-- Utilities
local function httpGet(url)
    local ok, r = pcall(function()
        if http and http.request   then return http.request({Url=url,Method="GET"}).Body
        elseif syn and syn.request then return syn.request({Url=url,Method="GET"}).Body
        elseif request             then return request({Url=url,Method="GET"}).Body
        elseif http_request        then return http_request({Url=url,Method="GET"}).Body
        elseif game.HttpGet        then return game:HttpGet(url) end
    end)
    return ok and r or nil
end
local function tw(n) if task then task.wait(n) else wait(n) end end
local function go(f) if task then task.spawn(f) else coroutine.wrap(f)() end end
