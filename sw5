local PRESET_FILE = "SqaysPresets.json"
local UserID = tostring(player.UserId)
local UserPresets = {}

local function loadPresetsFromDisk()
    local ok, data = pcall(function()
        if readfile then
            local raw = readfile(PRESET_FILE)
            if raw and raw ~= "" then
                return game:GetService("HttpService"):JSONDecode(raw)
            end
        end
    end)
    if ok and type(data) == "table" then
        UserPresets = data
        warn("[Sqays] Loaded presets for " .. #UserPresets .. " users")
    else
        UserPresets = {}
    end
end

local function savePresetsToDisk()
    if not writefile then return end
    pcall(function()
        local json = game:GetService("HttpService"):JSONEncode(UserPresets)
        writefile(PRESET_FILE, json)
        warn("[Sqays] Presets saved to disk")
    end)
end

