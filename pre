-- Auto Walk to Humanoid
local env = getgenv and getgenv() or _G
if env.AWTHLoaded then return end
env.AWTHLoaded = true; env.AWTHStop = false

-- ===== SERVICES =====
local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local WS = game:GetService("Workspace")
local TS = game:GetService("TweenService")

-- ===== STATE =====
local S = {
    enabled = false,
    running = false,
    speed = 0.6
}

-- ===== FIND CLOSEST HUMANOID =====
local function findClosestHumanoid()
    local closest = nil
    local closestDist = math.huge
    
    for _, obj in ipairs(WS:GetDescendants()) do
        if obj:IsA("Humanoid") then
            local hrp = obj.Parent:FindFirstChild("HumanoidRootPart")
            if hrp and hrp:IsA("BasePart") then
                local character = obj.Parent
                if character ~= LP.Character then
                    local hum = obj
                    if hum and hum.Health > 0 then
                        local playerHrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                        if playerHrp then
                            local dist = (playerHrp.Position - hrp.Position).Magnitude
                            if dist < closestDist then
                                closestDist = dist
                                closest = hrp
                            end
                        end
                    end
                end
            end
        end
    end
    
    return closest
end

-- ===== AUTO WALK LOOP =====
local function autoWalkLoop()
    S.running = true
    
    while S.enabled and not env.AWTHStop do
        local target = findClosestHumanoid()
        if not target then
            task.wait(1)
            continue
        end
        
        local char = LP.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then task.wait(0.5); continue end
        
        local dist = (hrp.Position - target.Position).Magnitude
        if dist > 5 then
            pcall(function()
                local tweenInfo = TweenInfo.new(dist * S.speed, Enum.EasingStyle.Linear)
                local tween = TS:Create(hrp, tweenInfo, {CFrame = CFrame.new(target.Position + Vector3.new(0, 0, 3))})
                tween:Play()
                tween.Completed:Wait()
            end)
        end
        
        task.wait(0.5)
    end
    
    S.running = false
end

-- ===== RAYFIELD =====
local Rayfield = nil
local ok, result = pcall(function() return loadstring(game:HttpGet('https://sirius.menu/rayfield'))() end)
if ok and result then Rayfield = result end
if not Rayfield then
    ok, result = pcall(function() return loadstring(game:HttpGet('https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/main/source.lua'))() end)
    if ok and result then Rayfield = result end
end
if not Rayfield then warn("[Auto Walk] Failed to load Rayfield UI"); return end

local Window = Rayfield:CreateWindow({
    Name = "Auto Walk to Humanoid",
    Icon = 0,
    LoadingTitle = "Auto Walk",
    LoadingSubtitle = "Walks to closest humanoid",
    ShowText = "Auto Walk",
    Theme = "DarkBlue",
    ToggleUIKeybind = Enum.KeyCode.K,
    DisableRayfieldPrompts = false,
    DisableBuildWarnings = true,
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "AutoWalk",
        FileName = "Config"
    },
    KeySystem = false
})

local Main = Window:CreateTab("🚶 Auto Walk")

Main:CreateSection("Auto Walk")
Main:CreateToggle({
    Name = "Enable Auto Walk",
    CurrentValue = false,
    Flag = "autoWalkEnabled",
    Callback = function(v)
        S.enabled = v
        if v and not S.running then
            task.spawn(autoWalkLoop)
            Rayfield:Notify({
                Title = "Auto Walk",
                Content = "Auto Walk started!",
                Duration = 5,
                Image = "info"
            })
        end
    end
})

Main:CreateSection("Speed")
Main:CreateSlider({
    Name = "Walk Speed (s)",
    Range = {0.2, 2},
    Increment = 0.1,
    CurrentValue = S.speed,
    Flag = "walkSpeed",
    Callback = function(v) S.speed = v end
})

Main:CreateSection("Info")
Main:CreateParagraph({
    Title = "📋 Info",
    Content = "Automatically walks to the closest humanoid\n\nUses tween movement to reach target\n\nSpeed can be adjusted in settings"
})

Rayfield:LoadConfiguration()
task.wait(1)

Rayfield:Notify({
    Title = "Auto Walk",
    Content = "Ready! Press K to toggle UI",
    Duration = 5,
    Image = "info"
})

-- ===== CONFIG LOADING =====
task.spawn(function()
    local flags = {}
    pcall(function() flags = Window.Flags or {} end)
    
    if flags.autoWalkEnabled then S.enabled = true end
    if flags.walkSpeed then S.speed = flags.walkSpeed end
    
    if S.enabled then
        task.wait(2)
        task.spawn(autoWalkLoop)
    end
end)

print("[Auto Walk] Ready")
