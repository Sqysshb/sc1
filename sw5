                hum:MoveTo(ore:GetPivot().Position)
            end
        end
    end; tw(CFG.MiningSpeed)
end end)

-- Upgrade loops
local function upgradeLoop(flag,speedKey,selKey,args)
    go(function() while true do
        if CFG[flag] and #CFG[selKey]>0 then
            for _,t in ipairs(CFG[selKey]) do
                local a={}; for _,x in ipairs(args) do table.insert(a,x) end
                table.insert(a,t); fire(table.unpack(a))
            end; tw(CFG[speedKey])
        else tw(0.1) end
    end end)
end
