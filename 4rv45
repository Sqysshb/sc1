-- 2) Teleport to trial lobby
local function teleportToTrial()
    local diff = type(T.difficulty) == "string" and T.difficulty or "Easy"
    local coord = TRIAL_COORDS[diff]
    if not coord then
        warn("[Sqays Hub] No coordinates for " .. tostring(diff))
        return false
    end

    local char = LP.Character or LP.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    if not hrp then
        warn("[Sqays Hub] HumanoidRootPart not found.")
        return false
    end

    pcall(function()
        hrp.CFrame = CFrame.new(coord)
        hrp.AssemblyLinearVelocity = Vector3.new()
    end)

    task.wait(0.5)
    local newPos = hrp.Position
    if (newPos - coord).Magnitude > 15 then
        warn("[Sqays Hub] Teleport failed.")
        T.teleportSuccess = false
        T.inTrial = false
        return false
    end

    print("[Sqays Hub] Teleport success.")
    T.teleportSuccess = true
    T.inTrial = true
    startLeaveTimer()
    return true
end

-- 3) Auto Join scheduler
local function joinScheduler()
    T.joinSchedulerRunning = true
    print("[Sqays Hub] Join scheduler started.")
    while T.joinEnabled and not env.NIStop do
        local t = os.date("*t")
        local min, sec = t.min, t.sec
        if (min == 29 or min == 59) and sec >= 10 and sec <= 15 then
            if T.lastJoinMinute ~= min then
                T.lastJoinMinute = min
                print("[Sqays Hub] Join time " .. min .. ":" .. sec)
                local ok = teleportToTrial()
                if Rayfield then
                    Rayfield:Notify({
                        Title = "Auto Join Trial",
                        Content = ok and ("Joined "..tostring(T.difficulty).." Trial!") or "Teleport failed!",
                        Duration = 5,
                        Image = ok and "info" or "error"
                    })
                end
                task.wait(5)
            end
        end
        if min ~= 29 and min ~= 59 then T.lastJoinMinute = -1 end
        task.wait(1)
    end
    T.joinSchedulerRunning = false
end

-- 4) Auto Grind scheduler (starts grind loop when trial mobs spawn)
local function grindScheduler()
    T.grindSchedulerRunning = true
    print("[Sqays Hub] Grind scheduler started.")
    while T.grindEnabled and not env.NIStop do
        local t = os.date("*t")
        local min, sec = t.min, t.sec
        if (min == 30 or min == 0) and sec >= 0 and sec <= 5 then
            if T.lastGrindMinute ~= min then
                T.lastGrindMinute = min
                print("[Sqays Hub] Grind time " .. min .. ":" .. sec)
                task.wait(2) -- wait for mobs to spawn
                if T.teleportSuccess and not T.grinding then
                    print("[Sqays Hub] Starting grind loop.")
                    task.spawn(function()
                        T.grinding = true
                        while T.grindEnabled and T.teleportSuccess and not env.NIStop do
                            local char = LP.Character
                            local hum = char and char:FindFirstChildOfClass("Humanoid")
                            if hum then
                                local target = findClosestMob()
                                if target then
                                    hum:MoveTo(target.Position)
                                end
                            end
                            task.wait(0.3)
                        end
                        T.grinding = false
                        print("[Sqays Hub] Grind loop stopped.")
                    end)
                end
                task.wait(5)
            end
        end
        if min ~= 30 and min ~= 0 then T.lastGrindMinute = -1 end
        task.wait(1)
    end
    T.grindSchedulerRunning = false
end

